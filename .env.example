# -----------------------------------------------
# Cópia este arquivo para .env e preencha os valores
# -----------------------------------------------
APP_NAME="Projeto Honda"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/Projeto-Honda/public

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=projeto_honda
DB_USERNAME=root
DB_PASSWORD=

SESSION_NAME=proj_honda_session
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=900
FORCE_HTTPS=false
HSTS_ENABLED=false
